#!/bin/sh
# Wait for mlan0 (mwifiex async probe) then bring up WiFi.
# Runs in background so it does not block other init scripts.

IFACE=mlan0
TIMEOUT=30

case "$1" in
start)
    (
        i=0
        while [ $i -lt $TIMEOUT ]; do
            [ -d /sys/class/net/$IFACE ] && break
            sleep 1
            i=$((i + 1))
        done
        if [ -d /sys/class/net/$IFACE ]; then
            /sbin/ifup $IFACE
            logger -t wifi "$IFACE up"
        else
            logger -t wifi "$IFACE not found after ${TIMEOUT}s"
        fi
    ) &
    echo "OK (background)"
    ;;
stop)
    /sbin/ifdown $IFACE 2>/dev/null
    killall wpa_supplicant 2>/dev/null
    echo "OK"
    ;;
*)
    echo "Usage: $0 {start|stop}"
    ;;
esac
